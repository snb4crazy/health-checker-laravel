{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "snb4crazy/health-checker-laravel",
    "description": "Starter Laravel package for scheduled infrastructure and app health checks.",
    "keywords": ["laravel", "health-check", "monitoring", "ops", "diagnostics"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Serhii Dymenko",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/mail": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/queue": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/redis": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^7.0|^8.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "PackageHealthChecker\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PackageHealthChecker\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PackageHealthChecker\\Laravel\\PackageHealthCheckerServiceProvider"
            ],
            "aliases": {
                "HealthChecker": "PackageHealthChecker\\Laravel\\Facades\\HealthChecker"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

